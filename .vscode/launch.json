    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}/playground"
        },
        {
            "name": "Debug All Jest Tests",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
              "--inspect-brk",
              "node_modules/jest/bin/jest.js",
              "--runInBand",
              "--config",
              "engineering/test/jest.config.js",
              "--verbose",
            ],
            "cwd": "${workspaceRoot}/CommonSql",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "port": 9229
        },
        {
          "name": "Debug Unit Tests",
