{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "allowJs": false,
        "sourceMap": true,
        "module": "commonjs",
        "target": "es6",
        "lib": ["es5", "es6", "dom"],
        "noImplicitAny": false,
        "noImplicitReturns": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "declaration": true
    },
    "include": ["./src/**/*"],
    "exclude": ["node_modules", "dist"]
}
