{
    "author": "Microsoft Corporation",
    "name": "common-sql-language-service-core",
    "version": "0.1.6",
    "description": "language service core for general sql language.",
    "license": "MIT",
    "repository": {
        "type": "git"
    },
    "devDependencies": {
        "@babel/core": "^7.26.10",
        "@babel/preset-env": "^7.26.9",
        "antlr4ts": "0.5.0-alpha.4",
        "antlr4ts-cli": "0.5.0-alpha.4",
        "babel-loader": "^8.4.1",
        "babel-polyfill": "^6.26.0",
        "copyfiles": "^2.1.1",
        "node-polyfill-webpack-plugin": "^1.1.4",
        "path": "^0.12.7",
        "terser-webpack-plugin": "^5.3.14",
        "ts-loader": "^9.2.6",
        "typescript": "^4.9.5",
        "typescript-map": "^0.0.7",
        "webpack": "5.93.0",
        "webpack-cli": "^5.1.4"
    },
    "scripts": {
        "auth": "vsts-npm-auth -c .npmrc -f",
        "generateCommonSqlParser": ".\\node_modules\\.bin\\antlr4ts src/language-service/Grammar/*.g4 -no-listener -visitor -o src/language-service/Parser/GeneratedParser  -Xexact-output-dir",
        "copyfiles": "copyfiles -f ./src/language-service/Grammar/* ./dist/CommonSqlCore/src/language-service/Grammar && copyfiles -f ./src/worker/package* ./dist/CommonSqlCore/src/worker/",
        "compile": "tsc -p ./tsconfig.json && npm run copyfiles",
        "webpack": "cd src/worker && node --max_old_space_size=16384 --openssl-legacy-provider ../../node_modules/webpack/bin/webpack.js && cd ../..",
        "build": "npm run generateCommonSqlParser && npm run webpack && npm run compile",
        "package:generateCommonSqlParser": "npm run package:createGeneratedParserFolder && .\\node_modules\\.bin\\antlr4ts -no-listener -visitor -o ./dist/CommonSqlCore/src/language-service/Parser/GeneratedParser  -Xexact-output-dir",
        "package:webpack": "cd ./dist/CommonSqlCore/src/worker && webpack --config package.webpack.config.js",
        "package:createGeneratedParserFolder": "if not exist \"./dist/CommonSqlCore/src/language-service/Parser/GeneratedParser\" mkdir \"./dist/CommonSqlCore/src/language-service/Parser/GeneratedParser\""
    },
    "keywords": [
        "Common Sql",
        "Language Service Core"
    ]
}
