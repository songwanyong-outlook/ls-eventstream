{
    "compilerOptions": {
        "outDir": "./dist",
        "allowJs": false,
        "sourceMap": true,
        "module": "commonjs",
        "target": "es6",
        "lib": [
            "es5",
            "es6",
            "dom"
        ],
        "noImplicitAny": false,
		"noImplicitReturns": true,
		"noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "experimentalDecorators": true
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": ["node_modules"]
}