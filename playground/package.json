{
    "name": "monaco-playground",
    "description": "monaco editor playground for language service.",
    "version": "0.0.1",
    "author": "Microsoft Corporation",
    "license": "MIT",
    "scripts": {
        "auth": "vsts-npm-auth -config .npmrc",
        "ls-test": "cross-env NODE_ENV=test npm start",
        "ls-test-local": "npm run copy-worker-file && npm run ls-test",
        "ls-debug": "npm run copy-worker-file && npm start",
        "ls-prod": "cross-env NODE_ENV=production npm start",
        "ls-prod-local": "npm run copy-worker-file && npm run ls-prod",
        "copy-worker-file": "copyfiles -f ../CommonSql/CommonSqlCore/src/worker/dist/*.js ./src/language_service_worker",
        "start": "node --max_old_space_size=16384 --openssl-legacy-provider ./node_modules/webpack-dev-server/bin/webpack-dev-server.js --port 8000",
        "build": "cross-env NODE_ENV=test node  --max_old_space_size=16384 --openssl-legacy-provider ./node_modules/webpack/bin/webpack.js --progress"
    },
    "devDependencies": {
        "@fluentui/react": "^8.28.2",
        "@fluentui/react-button": "^1.0.0-beta.35",
        "@fluentui/react-components": "^9.56.5",
        "@fluentui/react-icons": "^2.0.269",
        "@fluentui/react-toolbar": "^9.1.19",
        "@fluentui/web-components": "^3.0.0-beta.73",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.1",
        "@types/react": "^16.14.60",
        "@types/react-dom": "^16.8.4",
        "@types/react-transition-group": "2.9.2",
        "copyfiles": "^2.1.1",
        "cross-env": "^7.0.3",
        "css-loader": "^6.5.1",
        "file-loader": "^6.2.0",
        "glob": "^7.2.0",
        "html-webpack-plugin": "^5.5.3",
        "monaco-editor": "0.52.0",
        "node-polyfill-webpack-plugin": "^1.1.4",
        "react": "16.14.0",
        "react-dom": "16.14.0",
        "react-refresh": "^0.11.0",
        "style-loader": "^3.3.1",
        "ts-loader": "^9.2.6",
        "typescript": "^4.4.4",
        "webpack": "5.93.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.2",
        "worker-loader": "^3.0.8"
    },
    "dependencies": {
        "event-stream-language-service-facade": "^1.1.0"
    }
}
